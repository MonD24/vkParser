# ============================================================
#  .env — заполни перед запуском
# ============================================================

# --- VK ---
VK_TOKEN=your_vk_user_token_here      # токен пользователя VK (не группы!)
VK_USER_ID=123456                  # твой VK user id

# --- Telegram ---
TG_BOT_TOKEN=123456:123456  # токен бота из @BotFather
TG_CHAT_ID=123456      # твой chat_id (получи через @userinfobot)

# --- Настройки расписания (время по МСК, формат HH:MM) ---
SCHEDULE_TIMES=09:00,14:00,20:00

# --- Поиск конкурсов по ключевым словам (через запятую) ---
CONTEST_KEYWORDS=конкурс розыгрыш,giveaway приз,розыгрыш репост,конкурс подписка репост

# --- Сколько постов брать из поиска по каждому запросу ---
SEARCH_COUNT=20

# --- Безопасные паузы между действиями (секунды) ---
ACTION_DELAY_MIN=5
ACTION_DELAY_MAX=15

# --- Форвард личных сообщений VK → Telegram (true/false) ---
VK_FORWARD_MESSAGES=true
